1. CRÉER LA BASE MySQL (phpMyAdmin)
Ouvrir → SQL → coller :
sqlCREATE DATABASE lkl_bot CHARACTER SET utf8mb4 COLLATE utf8mb4_unicode_ci;
USE lkl_bot;

-- Positions ouvertes
CREATE TABLE positions (
    id INT AUTO_INCREMENT PRIMARY KEY,
    symbol VARCHAR(10),
    order_type ENUM('buy','sell'),
    lot DECIMAL(5,2),
    entry DECIMAL(10,5),
    sl DECIMAL(10,5),
    tp DECIMAL(10,5),
    reason TEXT,
    datetime DATETIME,
    status ENUM('OPEN','CLOSED') DEFAULT 'OPEN'
);

-- Annonces + décision bot
CREATE TABLE announcements (
    id INT AUTO_INCREMENT PRIMARY KEY,
    type VARCHAR(10) DEFAULT 'live',
    currency VARCHAR(5),
    event TEXT,
    impact ENUM('H','M','L'), -- 3 Stars / 2 Stars / 1 Star
    datetime DATETIME,
    bot_decision ENUM('USEFUL','NEUTRAL','IGNORE'),
    bot_reason TEXT
);

-- Analyses
CREATE TABLE reports (
    id INT AUTO_INCREMENT PRIMARY KEY,
    type VARCHAR(40),
    title VARCHAR(255),
    content TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Equity live
CREATE TABLE equity (
    id INT AUTO_INCREMENT PRIMARY KEY,
    balance DECIMAL(10,2),
    equity DECIMAL(10,2),
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

-- Trades fermés
CREATE TABLE trades (
    id INT AUTO_INCREMENT PRIMARY KEY,
    symbol VARCHAR(12),
    order_type ENUM('buy','sell'),
    profit DECIMAL(10,2),
    insight TEXT,
    created_at TIMESTAMP DEFAULT CURRENT_TIMESTAMP
);

