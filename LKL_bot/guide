5. API PHP → C:\wamp64\www\lkl_api\
receive.php → REÇOIT LE PUSH DU BOT
php<?php
// lkl_api/receive.php
header('Content-Type: application/json');
header('Access-Control-Allow-Origin: *');
header('Access-Control-Allow-Methods: POST');
header('Access-Control-Allow-Headers: Content-Type');

$input = json_decode(file_get_contents('php://input'), true);
if (!$input || !isset($input['table'])) {
    echo json_encode(['status' => 'error']);
    exit;
}

$pdo = new PDO('mysql:host=localhost;dbname=lkl_bot;charset=utf8mb4', 'root', '', [
    PDO::ATTR_ERRMODE => PDO::ERRMODE_EXCEPTION
]);

$table = $input['table'];
$data  = $input['data'];
$now   = date('Y-m-d H:i:s');

try {
    switch ($table) {
        case 'positions':
            $stmt = $pdo->prepare("INSERT INTO positions (symbol, order_type, lot, entry, sl, tp, reason, datetime, status) VALUES (?, ?, ?, ?, ?, ?, ?, ?, 'OPEN')");
            $stmt->execute([$data['symbol'], $data['type'], $data['lot'], $data['entry'], $data['sl'], $data['tp'], $data['reason'], $now]);
            break;
        case 'news':
            $stmt = $pdo->prepare("INSERT INTO announcements (currency, event, impact, datetime, bot_decision, bot_reason) VALUES (?, ?, ?, ?, ?, ?)");
            $stmt->execute([$data['currency'], $data['event'], $data['impact'], $data['time'], $data['decision'], $data['reason']]);
            break;
        case 'analysis':
            $stmt = $pdo->prepare("INSERT INTO reports (type, title, content, created_at) VALUES ('live_ta', ?, ?, ?)");
            $stmt->execute([$data['symbol'], $data['content'], $now]);
            break;
    }
    echo json_encode(['status' => 'success']);
} catch (Exception $e) {
    echo json_encode(['status' => 'error', 'msg' => $e->getMessage()]);
}
?>

get_live.php → RENVOIE TOUT EN TEMPS RÉEL
php<?php
// lkl_api/get_live.php
header('Content-Type: application/json');
$pdo = new PDO('mysql:host=localhost;dbname=lkl_bot;charset=utf8mb4', 'root', '');

$positions = $pdo->query("SELECT * FROM positions WHERE status='OPEN' ORDER BY datetime DESC LIMIT 10")->fetchAll(PDO::FETCH_ASSOC);
$news = $pdo->query("SELECT currency, event, impact, datetime, bot_decision, bot_reason FROM announcements WHERE DATE(datetime)=CURDATE() ORDER BY datetime DESC LIMIT 15")->fetchAll(PDO::FETCH_ASSOC);
$analysis = $pdo->query("SELECT title, content FROM reports WHERE type='live_ta' ORDER BY created_at DESC LIMIT 5")->fetchAll(PDO::FETCH_ASSOC);

$balance = json_decode(shell_exec('python mt5_balance.py'), true) ?? ['balance' => 0, 'equity' => 0];

echo json_encode([
    'positions' => $positions,
    'news' => $news,
    'analysis' => $analysis,
    'balance' => $balance['balance'],
    'equity' => $balance['equity'],
    'timestamp' => date('H:i:s')
]);
?>

